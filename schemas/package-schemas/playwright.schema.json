{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://metabuilder.dev/schemas/package-playwright.schema.json",
  "title": "Package Playwright Test Configuration",
  "description": "Playwright E2E test configuration for MetaBuilder packages.\n\nCRITICAL — URL rules:\n- baseURL in playwright.config.ts is 'http://localhost/workflowui/' (trailing slash)\n- navigate urls must be RELATIVE WITHOUT leading slash: 'login' not '/login'\n- A leading slash makes Playwright resolve to http://localhost/login (bypasses sub-path!)\n\nRun tests: SKIP_WEBSERVER=true npx playwright test e2e/tests.spec.ts e2e/workflowui-tests.spec.ts --config e2e/playwright.config.ts",
  "type": "object",
  "required": ["$schema", "tests"],
  "properties": {
    "$schema": {
      "type": "string",
      "const": "https://metabuilder.dev/schemas/package-playwright.schema.json"
    },
    "package": {
      "type": "string",
      "description": "Package identifier (lowercase letters, numbers, hyphens, underscores)",
      "pattern": "^[a-z0-9_-]+$"
    },
    "version": { "type": "string", "default": "1.0.0" },
    "description": { "type": "string" },
    "tests": {
      "type": "array",
      "description": "Test definitions",
      "items": { "$ref": "#/definitions/test" },
      "minItems": 1
    }
  },
  "definitions": {
    "test": {
      "type": "object",
      "required": ["name", "steps"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "skip": { "type": "boolean", "default": false, "description": "Skip this test — do NOT use; all tests must run" },
        "only": { "type": "boolean", "default": false },
        "timeout": { "type": "number", "minimum": 0 },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "examples": [["@smoke", "@critical"]]
        },
        "steps": {
          "type": "array",
          "items": { "$ref": "#/definitions/step" },
          "minItems": 1
        },
        "beforeEach": {
          "type": "array",
          "items": { "$ref": "#/definitions/step" },
          "description": "Steps run before the test (wraps the test in a describe block with hooks)"
        },
        "afterEach": {
          "type": "array",
          "items": { "$ref": "#/definitions/step" },
          "description": "Steps run after the test (cleanup)"
        },
        "parameterize": {
          "type": "object",
          "description": "Run the test once per data row, substituting ${varName} tokens in step fields",
          "required": ["data"],
          "properties": {
            "data": {
              "type": "array",
              "items": {
                "type": "object",
                "description": "Key-value pairs; values are substituted into step fields via ${key}",
                "additionalProperties": { "type": "string" }
              },
              "minItems": 1
            }
          }
        }
      }
    },
    "step": {
      "type": "object",
      "required": ["action"],
      "description": "A single Playwright action. Locator strategies: testId > role+text > label > placeholder > text > selector",
      "properties": {
        "description": { "type": "string" },
        "action": {
          "type": "string",
          "enum": [
            "navigate",
            "click",
            "dblclick",
            "fill",
            "type",
            "pageType",
            "select",
            "check",
            "uncheck",
            "hover",
            "focus",
            "blur",
            "press",
            "keyboard",
            "scroll",
            "wait",
            "waitForSelector",
            "waitForHidden",
            "waitForURL",
            "waitForNavigation",
            "waitForLoadState",
            "screenshot",
            "evaluate",
            "expect",
            "reload",
            "goBack",
            "goForward",
            "apiRequest"
          ]
        },
        "url": {
          "type": "string",
          "description": "URL for navigate/waitForURL. MUST be relative without leading slash: 'login' not '/login'. Leading slash bypasses workflowui baseURL sub-path."
        },
        "urlPattern": {
          "type": "string",
          "description": "URL substring pattern for waitForURL/waitForRequest/waitForResponse"
        },
        "waitUntil": {
          "type": "string",
          "enum": ["load", "domcontentloaded", "networkidle", "commit"],
          "description": "Navigation wait condition for navigate action"
        },
        "state": {
          "type": "string",
          "enum": ["load", "domcontentloaded", "networkidle", "attached", "detached", "visible", "hidden"],
          "description": "Load state for waitForLoadState, or element state for waitForSelector/waitForHidden"
        },
        "nth": {
          "type": "number",
          "minimum": 0,
          "description": "Zero-based index when multiple elements match the locator (e.g. 0 = first). Avoids strict mode errors."
        },
        "method": {
          "type": "string",
          "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"],
          "description": "HTTP method for apiRequest action"
        },
        "body": {
          "description": "Request body for apiRequest POST/PUT/PATCH"
        },
        "skipIf": {
          "type": "object",
          "description": "Skip this step if condition is met (e.g. element is hidden)",
          "required": ["selector", "state"],
          "properties": {
            "selector": { "type": "string" },
            "state": { "type": "string", "enum": ["hidden", "visible", "enabled", "disabled"] }
          }
        },
        "selector": { "type": "string", "description": "CSS selector" },
        "testId": { "type": "string", "description": "data-testid attribute value — preferred locator strategy" },
        "role": {
          "type": "string",
          "description": "ARIA role for getByRole",
          "enum": [
            "alert", "button", "checkbox", "cell", "columnheader", "combobox",
            "dialog", "figure", "form", "generic", "group", "heading",
            "img", "link", "list", "listbox", "listitem", "main",
            "menu", "menuitem", "navigation", "option", "presentation",
            "progressbar", "radio", "row", "rowheader", "searchbox",
            "separator", "slider", "spinbutton", "switch", "tab",
            "tabpanel", "textbox", "tree", "treeitem"
          ]
        },
        "text": { "type": "string", "description": "Text for getByText or getByRole name filter" },
        "label": { "type": "string", "description": "Label text for getByLabel" },
        "placeholder": { "type": "string", "description": "Placeholder for getByPlaceholder" },
        "alt": { "type": "string", "description": "Alt text for getByAltText" },
        "title": { "type": "string", "description": "Title attribute for getByTitle" },
        "value": { "description": "Value for fill/select/type actions" },
        "key": { "type": "string", "description": "Key for press action (e.g. 'Enter', 'Escape', 'Tab')" },
        "keys": {
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" } }
          ],
          "description": "Key(s) for keyboard action"
        },
        "script": { "type": "string", "description": "JavaScript code for evaluate action" },
        "timeout": { "type": "number", "minimum": 0, "description": "Step timeout in milliseconds" },
        "filename": { "type": "string", "description": "Filename for screenshot action" },
        "fullPage": { "type": "boolean", "default": false },
        "button": { "type": "string", "enum": ["left", "right", "middle"] },
        "clickCount": { "type": "number", "minimum": 1 },
        "delay": { "type": "number", "minimum": 0 },
        "x": { "type": "number", "description": "X coordinate for scroll" },
        "y": { "type": "number", "description": "Y coordinate for scroll" },
        "assertion": { "$ref": "#/definitions/assertion" }
      }
    },
    "assertion": {
      "type": "object",
      "required": ["matcher"],
      "properties": {
        "matcher": {
          "type": "string",
          "enum": [
            "toBeVisible",
            "toBeHidden",
            "toBeEnabled",
            "toBeDisabled",
            "toBeChecked",
            "toBeEditable",
            "toBeEmpty",
            "toContainText",
            "toHaveText",
            "toHaveValue",
            "toHaveCount",
            "toHaveAttribute",
            "toHaveClass",
            "toHaveCSS",
            "toHaveURL",
            "toHaveTitle",
            "toBeInViewport",
            "toHaveScreenshot",
            "custom"
          ]
        },
        "text": { "description": "Expected text (alias for expected, used with toContainText/toHaveText)" },
        "expected": { "description": "Expected value" },
        "value": { "description": "Expected value (alias, used with toHaveAttribute/toHaveCSS/toHaveValue)" },
        "name": { "type": "string", "description": "Attribute name for toHaveAttribute" },
        "property": { "type": "string", "description": "CSS property name for toHaveCSS" },
        "className": { "description": "Class name or regex for toHaveClass" },
        "count": { "type": "number", "description": "Expected count for toHaveCount" },
        "url": { "type": "string", "description": "Expected URL pattern for toHaveURL" },
        "title": { "type": "string", "description": "Expected title for toHaveTitle" },
        "script": { "type": "string", "description": "JavaScript for custom assertion" },
        "not": { "type": "boolean", "default": false, "description": "Negate the assertion" },
        "timeout": { "type": "number", "minimum": 0 }
      }
    }
  },
  "examples": [
    {
      "$schema": "https://metabuilder.dev/schemas/package-playwright.schema.json",
      "package": "workflowui-core",
      "description": "Core WorkflowUI E2E tests",
      "tests": [
        {
          "name": "login page displays correctly",
          "tags": ["@smoke", "@auth"],
          "steps": [
            {
              "action": "navigate",
              "url": "login",
              "description": "Navigate to login — relative URL, no leading slash!"
            },
            { "action": "waitForLoadState", "state": "domcontentloaded" },
            { "action": "expect", "testId": "auth-layout", "assertion": { "matcher": "toBeVisible" } },
            { "action": "expect", "testId": "email-input", "assertion": { "matcher": "toBeVisible" } }
          ]
        },
        {
          "name": "home page loads",
          "steps": [
            { "action": "navigate", "url": "", "description": "Empty string = workflowui home" },
            { "action": "waitForLoadState", "state": "domcontentloaded" },
            { "action": "expect", "testId": "header-actions", "assertion": { "matcher": "toBeVisible" } }
          ]
        }
      ]
    }
  ]
}
