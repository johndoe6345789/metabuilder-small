{
  "$schema": "https://metabuilder.dev/schemas/package-playwright.schema.json",
  "package": "package_manager",
  "description": "Package management - uses plugins page as equivalent",
  "version": "1.0",
  "tags": [
    "@admin",
    "@package-management",
    "@phase-3"
