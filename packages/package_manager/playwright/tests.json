    {
      "name": "admin can view list of packages",
      "description": "Plugins page displays available packages",
      "tags": [
        "@package-management",
        "@smoke"
      ],
      "timeout": 30000,
      "steps": [
        {
          "action": "navigate",
          "url": "plugins"
        },
        {
          "action": "waitForLoadState",
          "state": "domcontentloaded"
        },
        {
          "action": "expect",
          "selector": "body",
          "assertion": {
            "matcher": "toBeVisible"
          }
        }
      ]
    },
