{
  "name": "snippet_activity",
  "description": "Recent snippet activity — count of snippets created per day (last 30 days)",
  "entity": "Snippet",
  "select": [
    { "func": "count", "field": "id", "alias": "count" },
    "userId"
  ],
  "groupBy": ["userId"],
  "orderBy": [{ "field": "count", "dir": "desc" }],
  "limit": 100,
  "params": [
    { "name": "createdAfter", "type": "bigint", "required": false }
  ],
  "where": [
    { "field": "createdAt", "op": "gt", "param": "createdAfter" }
  ]
}
